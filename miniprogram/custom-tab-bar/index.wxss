/* ===== 自定义 tabBar ===== */

.tab-bar-wrap {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 999;
  /* 适配 iPhone 底部安全区 */
  padding-bottom: env(safe-area-inset-bottom);
}

/* 毛玻璃底板 */
.tab-bar-bg {
  position: absolute;
  inset: 0;
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-top: 1rpx solid rgba(74, 144, 226, 0.12);
  box-shadow: 0 -4rpx 24rpx rgba(74, 144, 226, 0.10);
}

.tab-bar-inner {
  position: relative;
  display: flex;
  align-items: flex-start;
  padding: 12rpx 0 4rpx;
}

/* ===== 单个 Tab 项 ===== */
.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  transition: transform 0.18s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.tab-item--active {
  transform: translateY(-4rpx);
}

/* ===== 图标区域 ===== */
.tab-icon-wrap {
  position: relative;
  width: 80rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 选中时的椭圆高亮背景 */
.tab-icon-bg {
  position: absolute;
  inset: 0;
  border-radius: 32rpx;
  background: transparent;
  transition: background 0.22s ease, transform 0.22s cubic-bezier(0.34, 1.56, 0.64, 1);
  transform: scale(0.6);
}

.tab-icon-bg--active {
  background: rgba(74, 144, 226, 0.12);
  transform: scale(1);
}

.tab-icon {
  position: relative;
  z-index: 1;
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ===== 资料库图标（纯 CSS 书本） ===== */
.icon-library {
  width: 38rpx;
  height: 38rpx;
  position: relative;
  border: 3rpx solid #94a3b8;
  border-radius: 4rpx 6rpx 6rpx 4rpx;
  background: transparent;
  transition: border-color 0.2s ease, transform 0.22s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.icon-library--active {
  border-color: #4A90E2;
  transform: scale(1.12);
}

/* 书脊 */
.icon-lib-spine {
  position: absolute;
  left: 6rpx;
  top: -3rpx;
  bottom: -3rpx;
  width: 3rpx;
  background: #94a3b8;
  transition: background 0.2s ease;
}

.icon-library--active .icon-lib-spine {
  background: #4A90E2;
}

/* 书页填充 */
.icon-lib-page {
  position: absolute;
  left: 12rpx;
  top: 0;
  bottom: 0;
  right: 0;
  background: #94a3b8;
  opacity: 0.08;
  border-radius: 0 4rpx 4rpx 0;
  transition: background 0.2s ease, opacity 0.2s ease;
}

.icon-library--active .icon-lib-page {
  background: #4A90E2;
  opacity: 0.14;
}

/* 书中文字横线 */
.icon-lib-lines {
  position: absolute;
  left: 16rpx;
  right: 5rpx;
  top: 8rpx;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.icon-lib-line {
  height: 2.5rpx;
  background: #94a3b8;
  border-radius: 2rpx;
  transition: background 0.2s ease;
}

.icon-library--active .icon-lib-line {
  background: #4A90E2;
}

/* ===== 我的图标（纯 CSS 人形） ===== */
.icon-mine {
  width: 38rpx;
  height: 38rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  padding-top: 2rpx;
  gap: 4rpx;
  transition: transform 0.22s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.icon-mine--active {
  transform: scale(1.12);
}

/* 头部圆圈 */
.icon-mine-head {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  border: 3rpx solid #94a3b8;
  transition: border-color 0.2s ease;
  flex-shrink: 0;
}

.icon-mine--active .icon-mine-head {
  border-color: #4A90E2;
}

/* 身体弧形 */
.icon-mine-body {
  width: 28rpx;
  height: 14rpx;
  border-radius: 14rpx 14rpx 0 0;
  border: 3rpx solid #94a3b8;
  border-bottom: none;
  transition: border-color 0.2s ease;
  flex-shrink: 0;
}

.icon-mine--active .icon-mine-body {
  border-color: #4A90E2;
}

/* ===== 文字标签 ===== */
.tab-label {
  font-size: 20rpx;
  color: #94a3b8;
  margin-top: 4rpx;
  font-weight: 400;
  letter-spacing: 0.5rpx;
  transition: color 0.2s ease, font-weight 0.2s ease;
  line-height: 1;
}

.tab-label--active {
  color: #4A90E2;
  font-weight: 600;
}

