page, html, body {
  margin: 0;
  padding: 0;
  width: 100%;
  max-width: 100%;
  overflow-x: hidden;
  box-sizing: border-box;
}

page {
  --td-brand-color: #4A90E2;
  --td-brand-color-hover: #5a9fe8;
  --td-brand-color-active: #3a7fd5;
  --td-brand-color-disabled: #a8cdf0;
  --td-brand-color-light: #eaf3fd;
  --td-brand-color-focus: rgba(74, 144, 226, 0.15);

  --primary: #4A90E2;
  --primary-light: #eaf3fd;
  --primary-dark: #3a7fd5;
  --primary-shadow: rgba(74, 144, 226, 0.25);

  --bg-page: #f4f6fb;
  --bg-card: #ffffff;
  --bg-tag: #f0f7ff;

  --text-primary: #1a2235;
  --text-secondary: #4b5563;
  --text-hint: #94a3b8;

  --border-color: #e8edf5;

  --radius-sm: 12rpx;
  --radius-md: 20rpx;
  --radius-lg: 28rpx;
  --radius-xl: 36rpx;

  --shadow-sm: 0 2rpx 12rpx rgba(74, 144, 226, 0.06);
  --shadow-md: 0 4rpx 24rpx rgba(74, 144, 226, 0.1);
  --shadow-lg: 0 8rpx 40rpx rgba(74, 144, 226, 0.14);

  --space-xs: 8rpx;
  --space-sm: 16rpx;
  --space-md: 24rpx;
  --space-lg: 32rpx;
  --space-xl: 48rpx;

  background-color: var(--bg-page);
  font-family: -apple-system, "PingFang SC", "Helvetica Neue", sans-serif;
  color: var(--text-primary);
  font-size: 28rpx;
  line-height: 1.5;
  overflow: hidden;
}

view, text, image, input, button, scroll-view {
  box-sizing: border-box;
}

.td-button--primary {
  --td-button-primary-color: var(--primary) !important;
  --td-button-primary-active-color: var(--primary-dark) !important;
}

.card {
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-md);
  overflow: hidden;
}

.page-hero {
  background: linear-gradient(135deg, #4A90E2 0%, #6aaee8 60%, #8ec5f0 100%);
  padding: 48rpx 32rpx 32rpx;
  position: relative;
  overflow: hidden;
}
.page-hero::before {
  content: '';
  position: absolute;
  top: -60rpx; right: -60rpx;
  width: 240rpx; height: 240rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.1);
}
.page-hero::after {
  content: '';
  position: absolute;
  bottom: -40rpx; left: -30rpx;
  width: 160rpx; height: 160rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.07);
}

/* ── Hero 区通用装饰圆（mine/detail/about/favorite 共用） ── */
.hero-decor-1 {
  position: absolute;
  top: -50rpx; right: -50rpx;
  width: 220rpx; height: 220rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.1);
  pointer-events: none;
}
.hero-decor-2 {
  position: absolute;
  bottom: -30rpx; left: -30rpx;
  width: 150rpx; height: 150rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.07);
  pointer-events: none;
}

/* ── 全局动画 ── */
@keyframes fadeSlideUp {
  from { opacity: 0; transform: translateY(30rpx); }
  to   { opacity: 1; transform: translateY(0); }
}
@keyframes fadeSlideDown {
  from { opacity: 0; transform: translateY(-20rpx); }
  to   { opacity: 1; transform: translateY(0); }
}
@keyframes fadeSlideLeft {
  from { opacity: 0; transform: translateX(20rpx); }
  to   { opacity: 1; transform: translateX(0); }
}
@keyframes fadeSlideRight {
  from { opacity: 0; transform: translateX(-20rpx); }
  to   { opacity: 1; transform: translateX(0); }
}
@keyframes shimmer {
  0%   { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}
@keyframes fadeIn {
  from { opacity: 0; }
  to   { opacity: 1; }
}
@keyframes scaleIn {
  from { opacity: 0; transform: scale(0.92); }
  to   { opacity: 1; transform: scale(1); }
}
@keyframes scalePop {
  0%   { transform: scale(1); }
  50%  { transform: scale(1.05); }
  100% { transform: scale(1); }
}
@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.6; }
}
@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-6rpx); }
}
@keyframes rotate {
  from { transform: rotate(0deg); }
  to   { transform: rotate(360deg); }
}
@keyframes slideInFromBottom {
  from { 
    opacity: 0; 
    transform: translateY(100%);
  }
  to { 
    opacity: 1; 
    transform: translateY(0);
  }
}

/* ── 骨架屏 shimmer ── */
.skeleton-shimmer {
  background: linear-gradient(90deg, #f0f4f8 25%, #e2eaf4 50%, #f0f4f8 75%);
  background-size: 200% 100%;
  animation: shimmer 1.4s infinite;
  border-radius: var(--radius-sm);
}

/* ── 微交互类 ── */
.press-scale {
  transition: transform 0.2s cubic-bezier(0.22, 1, 0.36, 1);
}
.press-scale:active {
  transform: scale(0.96);
}

.press-lift {
  transition: all 0.25s cubic-bezier(0.22, 1, 0.36, 1);
}
.press-lift:active {
  transform: translateY(-2rpx);
  box-shadow: var(--shadow-md);
}

.hover-brightness:active {
  filter: brightness(0.95);
}

/* 列表项交错动画 */
.stagger-item {
  animation: fadeSlideUp 0.4s cubic-bezier(0.22, 1, 0.36, 1) both;
}

/* 脉冲动画（用于通知点等） */
.pulse-dot {
  animation: pulse 2s ease-in-out infinite;
}

/* 旋转动画 */
.spin {
  animation: rotate 1s linear infinite;
}

/* 弹跳动画 */
.bounce {
  animation: bounce 0.6s ease infinite;
}

/* 玻璃态效果 */
.glass {
  background: rgba(255, 255, 255, 0.8);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
}

/* 渐变文字 */
.gradient-text {
  background: linear-gradient(135deg, var(--primary) 0%, #6aaee8 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.card-hover {
  transition: all 0.35s cubic-bezier(0.22, 1, 0.36, 1);
}
.card-hover:hover {
  transform: translateY(-4rpx);
  box-shadow: var(--shadow-lg);
}

::-webkit-scrollbar { display: none; }

