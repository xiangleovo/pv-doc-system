/* ── Library 页面样式 ── */
.library-page {
  width: 100%;
  height: 100vh;
  background: linear-gradient(180deg, var(--bg-page) 0%, #f8fafc 100%);
  overflow: hidden;
  animation: fadeIn 0.4s ease-out;
}

/* ── 搜索栏（固定在顶部） ── */
.search-wrap {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: linear-gradient(135deg, #3a7fd5 0%, #4A90E2 50%, #5aa0e8 100%);
  padding: 16rpx 24rpx 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 30rpx rgba(74, 144, 226, 0.25);
  animation: fadeSlideDown 0.4s cubic-bezier(0.22, 1, 0.36, 1);
}

.search-wrap::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -10%;
  width: 300rpx;
  height: 300rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%);
}

/* ── 可滚动内容区外层定位容器 ── */
.content-scroll {
  position: fixed;
  top: 0;   /* 初始值；onReady 后由 JS 动态设置为搜索栏实际高度 */
  bottom: 0;
  left: 0;
  right: 0;
  overflow: hidden;
}

/* t-pull-down-refresh 铺满外层容器，height: 100% 让组件内 scroll-view 自动填满 */
.pull-refresh {
  width: 100%;
  height: 100%;
  --td-loading-color: var(--primary);
  --td-pull-down-refresh-bg-color: transparent;
}

/* 底部占位（安全区） */
.scroll-bottom-safe {
  height: env(safe-area-inset-bottom);
  background: transparent;
}
.search-container {
  position: relative;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

/* 筛选按钮 */
.filter-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 16rpx 20rpx;
  background: rgba(255, 255, 255, 0.92);
  border-radius: 32rpx;
  color: #4A90E2;
  font-size: 26rpx;
  font-weight: 500;
  white-space: nowrap;
  flex-shrink: 0;
}

.filter-btn:active {
  background: rgba(255, 255, 255, 0.8);
}

/* 筛选图标 */
.svg-filter {
  display: inline-block;
  width: 32rpx;
  height: 32rpx;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 24 24' fill='none' stroke='%234A90E2' stroke-width='2'%3E%3Cpolygon points='22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3'%3E%3C/polygon%3E%3C/svg%3E");
  background-size: contain;
  background-repeat: no-repeat;
}

/* 筛选条件提示 */
.filter-hint {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 28rpx;
  background: linear-gradient(135deg, #F0F7FF 0%, #E8F4FD 100%);
  margin: 20rpx 24rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(74, 144, 226, 0.15);
  box-shadow: 0 4rpx 16rpx rgba(74, 144, 226, 0.08);
  animation: fadeSlideUp 0.4s 0.1s ease-out backwards;
}

.filter-tag {
  flex: 1;
  font-size: 28rpx;
  color: #4A90E2;
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.clear-filter {
  flex-shrink: 0;
  margin-left: 16rpx;
  font-size: 24rpx;
  color: #9CA3AF;
  padding: 10rpx 20rpx;
  background: rgba(255,255,255,0.8);
  border-radius: 24rpx;
  transition: all 0.25s ease;
}

.clear-filter:active {
  color: #4A90E2;
  background: rgba(74, 144, 226, 0.1);
  transform: scale(0.95);
}

.td-search {
  --td-search-bg-color: rgba(255,255,255,0.92);
  --td-search-border-radius: 100rpx;
  --td-search-padding: 0 24rpx;
  flex: 1;
}



/* ── 品牌筛选 ── */
.brand-filter {
  background: var(--bg-card);
  padding: 20rpx 28rpx 18rpx;
  border-bottom: 1.5rpx solid var(--border-color);
  overflow: visible;
}
.brand-scroll { white-space: nowrap; overflow: visible; }

.brand-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  margin-right: 32rpx;
  min-width: 116rpx;
  padding-top: 8rpx;
}
.brand-logo {
  width: 108rpx;
  height: 108rpx;
  border-radius: 50%;
  background: var(--bg-page);
  box-sizing: border-box;
  margin-bottom: 12rpx;
  transition: box-shadow 0.25s;
  /* 默认透明外圈，占位防止选中时尺寸跳变 */
  box-shadow: 0 0 0 3rpx transparent;
}
.brand-item.active .brand-logo {
  /* 用 box-shadow 模拟外圈蓝框，不占布局空间，不会被父容器裁切 */
  box-shadow: 0 0 0 3rpx var(--primary), 0 4rpx 16rpx rgba(74, 144, 226, 0.28);
}
.brand-name { font-size: 24rpx; color: var(--text-secondary); }
.brand-item.active .brand-name { color: var(--primary); font-weight: 600; }

/* ── 分类 Tab ── */
.category-tabs {
  background: var(--bg-card);
  padding: 16rpx 28rpx;
  margin-bottom: 20rpx;
  border-bottom: 1.5rpx solid var(--border-color);
}
.tabs-scroll { white-space: nowrap; }

.tab-item {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 14rpx 36rpx;
  margin-right: 14rpx;
  border-radius: 100rpx;
  font-size: 26rpx;
  color: var(--text-hint);
  background: var(--bg-page);
  border: 1.5rpx solid transparent;
  transition: all 0.2s;
}
.tab-item.active {
  background: rgba(74, 144, 226, 0.08);
  color: var(--primary);
  border-color: var(--primary);
  font-weight: 600;
}

/* ── 资料列表容器 ── */
.document-list {
  padding: 20rpx 24rpx 0;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

/* ── 骨架屏（t-skeleton 自带动效，此处只做间距） ── */
.skeleton-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding: 8rpx 0;
}
.skeleton-card {
  background: linear-gradient(135deg, #fff 0%, #fafbfc 100%);
  border-radius: var(--radius-lg);
  padding: 32rpx 28rpx;
  box-shadow: var(--shadow-sm), 0 1rpx 3rpx rgba(0,0,0,0.02);
  border: 1rpx solid rgba(74, 144, 226, 0.04);
  animation: fadeSlideUp 0.4s cubic-bezier(0.22, 1, 0.36, 1) both;
}
.skeleton-card:nth-child(1) { animation-delay: 0ms; }
.skeleton-card:nth-child(2) { animation-delay: 80ms; }
.skeleton-card:nth-child(3) { animation-delay: 160ms; }
.skeleton-card:nth-child(4) { animation-delay: 240ms; }

/* ── 搜索提示 ── */
.search-hint {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: linear-gradient(135deg, var(--primary-light) 0%, #E8F4FD 100%);
  border-radius: var(--radius-md);
  padding: 20rpx 24rpx;
  font-size: 26rpx;
  color: var(--primary);
  margin-bottom: 8rpx;
  border: 1rpx solid rgba(74, 144, 226, 0.1);
  animation: fadeSlideUp 0.3s ease-out;
}
.search-hint text { flex: 1; }
.clear-btn { display: flex; align-items: center; }

/* ── 空状态 / 加载 / 无数据 ── */
.empty-wrap, .no-data-wrap {
  padding: 100rpx 40rpx 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 32rpx;
  animation: fadeSlideUp 0.5s ease-out;
}
.empty-icon { 
  width: 200rpx; 
  height: 200rpx; 
  opacity: 0.5;
  animation: bounce 2s ease-in-out infinite;
}
.empty-desc { 
  font-size: 30rpx; 
  color: var(--text-hint); 
  text-align: center;
  font-weight: 500;
  line-height: 1.6;
}
.empty-subdesc {
  font-size: 26rpx;
  color: var(--text-hint);
  opacity: 0.7;
  text-align: center;
}
.loading-wrap { 
  display: flex; 
  justify-content: center; 
  padding: 60rpx 0;
}

/* ── 加载更多区域 ── */
.load-more-wrap {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 16rpx 0 4rpx;
}
.load-more-loading {
  display: flex;
  align-items: center;
  gap: 12rpx;
  color: var(--text-hint);
  font-size: 24rpx;
}
.load-more-end {
  font-size: 24rpx;
  color: var(--text-hint);
  letter-spacing: 2rpx;
  padding: 8rpx 0;
}
.load-more-trigger {
  font-size: 26rpx;
  color: var(--primary);
  padding: 14rpx 40rpx;
  border: 2rpx solid var(--primary);
  border-radius: 100rpx;
  background: linear-gradient(135deg, rgba(74, 144, 226, 0.05) 0%, transparent 100%);
  transition: all 0.3s ease;
  box-shadow: 0 4rpx 16rpx rgba(74, 144, 226, 0.1);
}
.load-more-trigger:active {
  background: var(--primary);
  color: #fff;
  transform: scale(0.97);
  box-shadow: 0 6rpx 20rpx rgba(74, 144, 226, 0.25);
}

.search-left-icon { display: flex; align-items: center; padding-right: 8rpx; }

/* ── SVG 图标尺寸覆盖 ── */
.svg-browse        { width: 24rpx; height: 24rpx; }
.svg-chevron-right { width: 32rpx; height: 32rpx; }
.svg-search        { width: 28rpx; height: 28rpx; }
.svg-close         { width: 28rpx; height: 28rpx; }

/* ── 列表区淡出淡入（切换品牌/分类筛选时） ── */
.document-list-wrap {
  transition: opacity 0.12s ease, transform 0.12s ease;
  opacity: 1;
  transform: translateY(0);
}
.document-list-wrap.list-fading {
  opacity: 0;
  transform: translateY(8rpx);
  pointer-events: none;
}

