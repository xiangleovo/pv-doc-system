/* 页面根容器 */
.filter-page {
  width: 100vw;
  height: 100vh;
  margin: 0;
  padding: 0;
  overflow: hidden;
}

/* 顶部一体化区域 */
.top-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  width: 100vw;
  z-index: 100;
  background: linear-gradient(135deg, #3a7fd5 0%, #4A90E2 50%, #5aa0e8 100%);
  box-shadow: 0 4rpx 30rpx rgba(74, 144, 226, 0.35);
}

/* 顶部装饰动画 */
.top-header::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -10%;
  width: 300rpx;
  height: 300rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255,255,255,0.12) 0%, transparent 70%);
  animation: pulse 4s ease-in-out infinite;
}

.top-header::after {
  content: '';
  position: absolute;
  bottom: -30%;
  left: -5%;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255,255,255,0.08) 0%, transparent 70%);
  animation: pulse 4s ease-in-out infinite 1s;
}

.header-content {
  display: flex;
  align-items: center;
  padding: 32rpx 28rpx;
  gap: 24rpx;
}

/* 左侧公司信息 */
.company-section {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.company-logo {
  flex-shrink: 0;
}

/* 公司 logo 图片 */
.company-logo-img {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(255, 255, 255, 0.4);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15), 0 0 0 4rpx rgba(255,255,255,0.1);
  display: block;
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}

.company-logo-img:active {
  transform: scale(0.95);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

.company-text {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.company-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: 0.5rpx;
}

.company-subtitle {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 500;
}

/* 右侧搜索框 */
.search-section {
  flex: 1;
  min-width: 0;
  position: relative;
}

.search-box {
  display: flex;
  align-items: center;
  height: 72rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 36rpx;
  padding: 0 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08), inset 0 1rpx 0 rgba(255,255,255,0.8);
  transition: all 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  backdrop-filter: blur(10rpx);
}

.search-box:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.06);
}

.search-box::before {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: 36rpx;
  padding: 2rpx;
  background: linear-gradient(135deg, rgba(255,255,255,0.8), rgba(255,255,255,0.2));
  -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
  mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
  -webkit-mask-composite: xor;
  mask-composite: exclude;
  pointer-events: none;
}

.search-icon-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 32rpx;
  height: 32rpx;
  margin-right: 12rpx;
}

.search-placeholder {
  font-size: 28rpx;
  color: #999;
}

/* 主内容区 */
.main-content {
  display: flex;
  height: calc(100vh - 148rpx - 100rpx);
  margin-top: 148rpx;
}

/* 左侧分类菜单 */
.category-menu {
  width: 180rpx;
  background: linear-gradient(180deg, #FAFAFA 0%, #F5F7FA 100%);
}

.menu-scroll {
  height: 100%;
  margin: 0;
  padding: 0;
  -webkit-overflow-scrolling: touch;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx 20rpx;
  position: relative;
  margin: 8rpx 12rpx;
  border-radius: 16rpx;
}

.menu-item:active {
  transform: scale(0.96);
  background: rgba(74, 144, 226, 0.05);
}

.menu-item.active {
  background: #FFFFFF;
  box-shadow: 0 4rpx 16rpx rgba(74, 144, 226, 0.12);
}

.menu-item.active::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 32rpx;
  background: linear-gradient(180deg, #4A90E2, #6aaee8);
  border-radius: 0 3rpx 3rpx 0;
}

.menu-text {
  font-size: 26rpx;
  color: #5A5A5A;
  font-weight: 500;
  text-align: center;
  line-height: 1.4;
  padding: 0 4rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 100%;
}

.menu-item.active .menu-text {
  color: #4A90E2;
  font-weight: 600;
  font-size: 28rpx;
}

/* 右侧品牌列表 */
.brand-list {
  flex: 1;
  background: linear-gradient(180deg, #FFFFFF 0%, #FAFBFC 100%);
}

.brand-scroll {
  height: 100%;
  -webkit-overflow-scrolling: touch;
}

/* 品牌网格 */
.brand-grid {
  padding: 20rpx 24rpx 60rpx;
}

.brand-grid .brand-card {
  margin-bottom: 20rpx;
}

.brand-grid .brand-card:last-child {
  margin-bottom: 0;
}

/* 品牌卡片 */
.brand-card {
  display: flex;
  align-items: center;
  padding: 28rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  border: 1rpx solid rgba(74, 144, 226, 0.08);
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05), 0 1rpx 4rpx rgba(0, 0, 0, 0.02);
  transition: all 0.35s cubic-bezier(0.22, 1, 0.36, 1);
  position: relative;
  overflow: hidden;
  animation: fadeSlideUp 0.4s cubic-bezier(0.22, 1, 0.36, 1) both;
}

.brand-card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 4rpx;
  background: linear-gradient(180deg, #4A90E2, #6aaee8);
  opacity: 0;
  transition: all 0.3s ease;
  transform: scaleY(0);
  transform-origin: center;
}

.brand-card::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(74, 144, 226, 0.03) 0%, transparent 50%);
  opacity: 0;
  transition: opacity 0.3s ease;
  pointer-events: none;
}

.brand-card:active {
  transform: translateY(-2rpx) scale(0.99);
  box-shadow: 0 8rpx 30rpx rgba(74, 144, 226, 0.15), 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  border-color: rgba(74, 144, 226, 0.2);
}

.brand-card:active::before {
  opacity: 1;
  transform: scaleY(1);
}

.brand-card:active::after {
  opacity: 1;
}

/* 品牌logo */
.brand-card-logo {
  flex-shrink: 0;
  position: relative;
  margin-right: 20rpx;
}

/* 品牌logo容器 */
.card-avatar-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(74, 144, 226, 0.2), 0 0 0 3rpx rgba(255,255,255,0.8);
  background: linear-gradient(135deg, #4A90E2 0%, #6aaee8 100%);
  transition: all 0.3s cubic-bezier(0.22, 1, 0.36, 1);
}

.brand-card:active .card-avatar-wrap {
  transform: scale(1.05);
  box-shadow: 0 6rpx 24rpx rgba(74, 144, 226, 0.3), 0 0 0 4rpx rgba(255,255,255,0.9);
}

/* 品牌logo图片 */
.card-avatar-img {
  width: 100%;
  height: 100%;
  display: block;
}

/* logo加载失败的占位文字 */
.card-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #4A90E2 0%, #6aaee8 100%);
  color: #FFFFFF;
}

.brand-badge {
  position: absolute;
  top: -6rpx;
  right: -6rpx;
  padding: 6rpx 12rpx;
  border-radius: 16rpx;
  font-size: 18rpx;
  font-weight: 700;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
  backdrop-filter: blur(4rpx);
  border: 1rpx solid rgba(255,255,255,0.3);
}

.brand-badge.badge-1 {
  background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
  color: #FFFFFF;
  text-shadow: 0 1rpx 2rpx rgba(0,0,0,0.1);
}

.brand-badge.badge-2 {
  background: linear-gradient(135deg, #4A90E2 0%, #6aaee8 100%);
  color: #FFFFFF;
  text-shadow: 0 1rpx 2rpx rgba(0,0,0,0.1);
}

/* 品牌信息 */
.brand-card-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.brand-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a2235;
  letter-spacing: 0.3rpx;
  transition: color 0.3s ease;
}

.brand-card:active .brand-name {
  color: #4A90E2;
}

.brand-en {
  font-size: 22rpx;
  color: #94a3b8;
  font-weight: 400;
  letter-spacing: 0.5rpx;
}

.brand-docs {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 22rpx;
  color: #94a3b8;
  font-weight: 500;
}

/* 品牌卡片箭头 */
.brand-card-arrow {
  flex-shrink: 0;
  margin-left: 12rpx;
  opacity: 0.5;
}
