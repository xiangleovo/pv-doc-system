# 后端环境变量配置模板
# 复制此文件为 .env 并填写真实值
# cp .env.example .env

# ── 数据库配置 ──────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASSWORD=your_database_password

# 数据库连接池配置（通常无需修改）
DB_POOL_MAX=10
DB_POOL_MIN=0
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000

# ── JWT 密钥 ─────────────────────────────────────────────
# 请使用随机高强度字符串，推荐 32 位以上
# 生成命令：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_here

# ── 服务器配置 ────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# 服务器对外访问地址（用于生成文件完整 URL）
BASE_URL=https://your-server-domain.com

# ── CORS 配置 ─────────────────────────────────────────────
# 支持多个域名，逗号分隔；留空或设为 * 则允许所有来源
CORS_ORIGIN=https://your-admin-domain.com,http://localhost:5173

# ── 文件上传限制 ──────────────────────────────────────────
# 单位：字节，默认 2MB
MAX_FILE_SIZE=2097152

# ── 默认管理员账号配置 ──────────────────────────────────
# 首次启动时如果数据库中无管理员，将使用此账号自动创建
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_admin_password_here
# 管理员昵称
ADMIN_NICKNAME=管理员

# ── 微信小程序配置 ─────────────────────────────────────────
# 在微信公众平台 (mp.weixin.qq.com) 获取
WX_APPID=your_wx_appid
WX_SECRET=your_wx_appsecret

# ── 腾讯云 COS 配置（用于文件存储）─────────────────────────
# 在腾讯云控制台 > 访问管理 > API 密钥管理 中获取
COS_SECRET_ID=your_cos_secret_id
COS_SECRET_KEY=your_cos_secret_key
# 存储桶名称，格式：bucketname-appid
COS_BUCKET=your-bucket-1234567890
# 存储桶所在地域，如 ap-guangzhou
COS_REGION=ap-guangzhou
# 自定义域名（可选，留空则使用默认 COS 域名）
COS_DOMAIN=
# 文件存储路径前缀
COS_PREFIX=pdfs/
